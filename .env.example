# ============================================================
# FUTURISMO BACKEND - Template de configuracion
# ============================================================
# Copiar a .env y ajustar valores.
# Este archivo es para DESARROLLO LOCAL.
# Railway usa variables de entorno en su dashboard.
# ============================================================

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"
JWT_SECRET="your_jwt_secret_here"
PORT=4025
NODE_ENV=development
TZ=America/Lima

# ==================== WASABI STORAGE ====================
WASABI_ACCESS_KEY=""
WASABI_SECRET_KEY=""
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.wasabisys.com
WASABI_UPLOADS_BUCKET=futurismo-uploads
WASABI_BACKUPS_BUCKET=futurismo-backups
WASABI_PRESIGNED_EXPIRES=3600
# URL pública del backend; deja vacío en desarrollo para usar paths relativos.
BACKEND_PUBLIC_URL=
