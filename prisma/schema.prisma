generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model active_tours {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_id        String            @unique @db.Uuid
  guide_id              String?           @db.Uuid
  status                String            @default("not_started") @db.VarChar(20)
  current_stop_index    Int               @default(0) @db.SmallInt
  started_at            DateTime?         @db.Timestamptz(6)
  ended_at              DateTime?         @db.Timestamptz(6)
  last_location_update  DateTime?         @db.Timestamptz(6)
  emergency_protocol_id String?           @db.Uuid
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  protocols             protocols?        @relation(fields: [emergency_protocol_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_active_tours__emergency_protocol_id__protocols")
  guides                guides?           @relation(fields: [guide_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_active_tours__guide_id__guides")
  reservations          reservations      @relation(fields: [reservation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_active_tours__reservation_id__reservations")
  guide_locations       guide_locations[]
  monitoring_alerts     monitoring_alerts[]
  tour_incidents        tour_incidents[]
  tour_photos           tour_photos[]
  tour_progress         tour_progress[]

  @@index([emergency_protocol_id], map: "idx_active_tours__emergency_protocol_id")
  @@index([guide_id], map: "idx_active_tours__guide_id")
  @@index([status], map: "idx_active_tours__status")
}

model agencies {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String                   @unique(map: "agencies_user_id_unique") @db.Uuid
  business_name          String                   @db.VarChar(200)
  ruc                    String                   @unique(map: "agencies_ruc_unique") @db.VarChar(11)
  position               String?                  @db.VarChar(100)
  agency_phone           String?                  @db.VarChar(20)
  agency_email           String?                  @db.VarChar(255)
  agency_address         String?
  agency_logo            String?
  whatsapp               String?                  @db.VarChar(20)
  status                 String                   @default("active") @db.VarChar(20)
  level                  String                   @default("bronze") @db.VarChar(20)
  verified               Boolean                  @default(false)
  rating                 Decimal?                 @db.Decimal(3, 2)
  total_reviews          Int                      @default(0)
  total_tours            Int                      @default(0)
  available_points       Int                      @default(0)
  total_points           Int                      @default(0)
  certifications         Json?                    @default("[]")
  specialties            Json?                    @default("[]")
  languages              Json?                    @default("[]")
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  contacts               Json?                    @default("[]")
  payment_methods        Json?                    @default("[]")
  users                  users                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_agencies__user_id__users")
  agency_payment_methods agency_payment_methods[]
  guides                 guides[]
  points_history         points_history[]
  redemptions            redemptions[]
  reservations           reservations[]
  service_requests       service_requests[]

  @@index([business_name], map: "idx_agencies__business_name")
  @@index([level], map: "idx_agencies__level")
  @@index([status], map: "idx_agencies__status")
}

model audit_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(50)
  entity_type String   @db.VarChar(50)
  entity_id   String?  @db.Uuid
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.Inet
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  users       users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_logs__user_id__users")

  @@index([action], map: "idx_audit_logs__action")
  @@index([created_at], map: "idx_audit_logs__created_at")
  @@index([entity_id], map: "idx_audit_logs__entity_id")
  @@index([entity_type], map: "idx_audit_logs__entity_type")
  @@index([user_id], map: "idx_audit_logs__user_id")
}

model chat_participants {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id      String    @db.Uuid
  user_id      String    @db.Uuid
  role         String    @default("member") @db.VarChar(20)
  last_read_at DateTime? @db.Timestamptz(6)
  unread_count Int       @default(0)
  is_muted     Boolean   @default(false)
  joined_at    DateTime  @default(now()) @db.Timestamptz(6)
  left_at      DateTime? @db.Timestamptz(6)
  chats        chats     @relation(fields: [chat_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_participants__chat_id__chats")
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_participants__user_id__users")

  @@unique([chat_id, user_id], map: "chat_participants_chat_user_key")
  @@index([chat_id], map: "idx_chat_participants__chat_id")
  @@index([user_id], map: "idx_chat_participants__user_id")
}

model chats {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String?             @db.VarChar(200)
  chat_type         String              @default("direct") @db.VarChar(20)
  is_from_agenda    Boolean             @default(false)
  reservation_id    String?             @db.Uuid
  last_message_at   DateTime?           @db.Timestamptz(6)
  created_by        String              @db.Uuid
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  chat_participants chat_participants[]
  users             users               @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chats__created_by__users")
  reservations      reservations?       @relation(fields: [reservation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chats__reservation_id__reservations")
  messages          messages[]

  @@index([chat_type], map: "idx_chats__chat_type")
  @@index([last_message_at], map: "idx_chats__last_message_at")
  @@index([reservation_id], map: "idx_chats__reservation_id")
}

model documents {
  id                                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                            String    @db.Uuid
  document_type                      String    @db.VarChar(50)
  name                               String    @db.VarChar(200)
  file_url                           String
  file_type                          String?   @db.VarChar(50)
  file_size                          BigInt?
  expiry_date                        DateTime? @db.Date
  verification_status                String    @default("pending") @db.VarChar(20)
  verified_by                        String?   @db.Uuid
  verified_at                        DateTime? @db.Timestamptz(6)
  created_at                         DateTime  @default(now()) @db.Timestamptz(6)
  users_documents_user_idTousers     users     @relation("documents_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_documents__user_id__users")
  users_documents_verified_byTousers users?    @relation("documents_verified_byTousers", fields: [verified_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_documents__verified_by__users")

  @@index([document_type], map: "idx_documents__document_type")
  @@index([expiry_date], map: "idx_documents__expiry_date")
  @@index([user_id], map: "idx_documents__user_id")
  @@index([verification_status], map: "idx_documents__verification_status")
}

model drivers {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name       String             @db.VarChar(100)
  last_name        String             @db.VarChar(100)
  document_type    String             @default("DNI") @db.VarChar(10)
  document_number  String             @unique @db.VarChar(20)
  phone            String?            @db.VarChar(20)
  email            String?            @db.VarChar(255)
  license_number   String             @unique @db.VarChar(30)
  license_category String             @db.VarChar(10)
  license_expiry   DateTime?          @db.Date
  photo_url        String?
  status           String             @default("active") @db.VarChar(20)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  tour_assignments tour_assignments[]

  @@index([first_name], map: "idx_drivers__first_name")
  @@index([license_category], map: "idx_drivers__license_category")
  @@index([license_expiry], map: "idx_drivers__license_expiry")
  @@index([status], map: "idx_drivers__status")
}

model emergency_categories {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String      @unique @db.VarChar(100)
  description    String?
  icon           String?     @db.VarChar(50)
  severity_level Int         @default(1) @db.SmallInt
  is_active      Boolean     @default(true)
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  color          String?     @default("#EF4444") @db.VarChar(20)
  protocols      protocols[]
}

model emergency_contact_types {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  icon        String?   @default("📞") @db.VarChar(50)
  description String?
  color       String?   @default("#6B7280") @db.VarChar(20)
  priority    Int?      @default(1) @db.SmallInt
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_emergency_contact_types__is_active")
  @@index([name], map: "idx_emergency_contact_types__name")
  @@index([priority], map: "idx_emergency_contact_types__priority")
}

model emergency_contacts {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String     @db.VarChar(200)
  contact_type    String     @db.VarChar(30)
  phone           String     @db.VarChar(20)
  phone_secondary String?    @db.VarChar(20)
  address         String?
  location_id     String?    @db.Uuid
  is_24_hours     Boolean    @default(false)
  notes           String?
  is_active       Boolean    @default(true)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  locations       locations? @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_emergency_contacts__location_id__locations")

  @@index([contact_type], map: "idx_emergency_contacts__contact_type")
  @@index([location_id], map: "idx_emergency_contacts__location_id")
}

model emergency_materials {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String                     @db.VarChar(200)
  category                 String                     @db.VarChar(100)
  description              String?
  quantity                 Int?                       @default(1)
  unit                     String?                    @default("unidad") @db.VarChar(50)
  is_mandatory             Boolean?                   @default(false)
  icon                     String?                    @default("📦") @db.VarChar(50)
  notes                    String?
  is_active                Boolean?                   @default(true)
  created_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  emergency_material_items emergency_material_items[]

  @@index([category], map: "idx_emergency_materials__category")
  @@index([is_active], map: "idx_emergency_materials__is_active")
  @@index([is_mandatory], map: "idx_emergency_materials__is_mandatory")
}

model evaluation_criteria {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(50)
  label       String   @db.VarChar(100)
  description String?
  order_index Int      @default(0) @db.SmallInt
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_evaluation_criteria__is_active")
}

model expense_categories {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @db.VarChar(100)
  value       String     @unique @db.VarChar(50)
  icon        String?    @db.VarChar(50)
  color       String?    @db.VarChar(20)
  description String?
  is_active   Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  expenses    expenses[]

  @@index([value], map: "idx_expense_categories__value")
}

model expenses {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guide_id           String             @db.Uuid
  category_id        String             @db.Uuid
  tour_id            String?            @db.Uuid
  reservation_id     String?            @db.Uuid
  amount             Decimal            @db.Decimal(10, 2)
  description        String?
  date               DateTime           @db.Date
  receipt_url        String?
  notes              String?
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  expense_categories expense_categories @relation(fields: [category_id], references: [id])
  guides             guides             @relation(fields: [guide_id], references: [id], onDelete: Cascade)
  reservations       reservations?      @relation(fields: [reservation_id], references: [id])
  tours              tours?             @relation(fields: [tour_id], references: [id])

  @@index([category_id], map: "idx_expenses__category_id")
  @@index([date], map: "idx_expenses__date")
  @@index([guide_id], map: "idx_expenses__guide_id")
  @@index([tour_id], map: "idx_expenses__tour_id")
}

model feedback {
  id                                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                            String        @db.Uuid
  feedback_type                      String        @db.VarChar(30)
  subject                            String        @db.VarChar(200)
  message                            String
  status                             String        @default("pending") @db.VarChar(20)
  priority                           String        @default("normal") @db.VarChar(10)
  response                           String?
  responded_by                       String?       @db.Uuid
  responded_at                       DateTime?     @db.Timestamptz(6)
  created_at                         DateTime      @default(now()) @db.Timestamptz(6)
  rating                             Int?          @db.SmallInt
  suggestions_text                   String?
  users_feedback_responded_byTousers users?        @relation("feedback_responded_byTousers", fields: [responded_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_feedback__responded_by__users")
  users_feedback_user_idTousers      users         @relation("feedback_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_feedback__user_id__users")
  suggestions                        suggestions[]

  @@index([created_at], map: "idx_feedback__created_at")
  @@index([feedback_type], map: "idx_feedback__feedback_type")
  @@index([status], map: "idx_feedback__status")
  @@index([user_id], map: "idx_feedback__user_id")
}

model financial_calculations {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guide_id           String   @db.Uuid
  tour_price         Decimal  @db.Decimal(10, 2)
  participants       Int
  guide_commission   Decimal  @db.Decimal(5, 2)
  estimated_expenses Decimal  @db.Decimal(10, 2)
  gross_income       Decimal  @db.Decimal(10, 2)
  net_income         Decimal  @db.Decimal(10, 2)
  profit_margin      Decimal  @db.Decimal(5, 2)
  notes              String?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  guides             guides   @relation(fields: [guide_id], references: [id], onDelete: Cascade)

  @@index([created_at], map: "idx_financial_calculations__created_at")
  @@index([guide_id], map: "idx_financial_calculations__guide_id")
}

model guide_locations {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  active_tour_id String       @db.Uuid
  latitude       Decimal      @db.Decimal(10, 7)
  longitude      Decimal      @db.Decimal(10, 7)
  accuracy       Decimal?     @db.Decimal(6, 2)
  speed          Decimal?     @db.Decimal(6, 2)
  recorded_at    DateTime     @default(now()) @db.Timestamptz(6)
  active_tours   active_tours @relation(fields: [active_tour_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_guide_locations__active_tour_id__active_tours")

  @@index([active_tour_id], map: "idx_guide_locations__active_tour_id")
  @@index([recorded_at], map: "idx_guide_locations__recorded_at")
}

model guides {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String                   @unique(map: "guides_user_id_unique") @db.Uuid
  agency_id              String?                  @db.Uuid
  guide_type             String                   @default("FREELANCE") @db.VarChar(20)
  license_number         String?                  @db.VarChar(50)
  years_of_experience    Int?                     @default(0)
  languages              Json?                    @default("[]")
  specialties            Json?                    @default("[]")
  certifications         Json?                    @default("[]")
  museums                Json?                    @default("[]")
  bio                    String?
  education              String?
  hourly_rate            Decimal?                 @db.Decimal(10, 2)
  guide_photo            String?
  rating                 Decimal?                 @db.Decimal(3, 2)
  online                 Boolean                  @default(false)
  bank_name              String?                  @db.VarChar(100)
  account_type           String?                  @db.VarChar(20)
  account_number         String?                  @db.VarChar(30)
  interbank_code         String?                  @db.VarChar(30)
  account_holder         String?                  @db.VarChar(200)
  currency               String?                  @default("PEN") @db.VarChar(3)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  status                 String?                  @default("active") @db.VarChar(20)
  price_per_person       Decimal?                 @db.Decimal(10, 2)
  work_zones             Json?                    @default("[]")
  active_tours           active_tours[]
  availability           availability[]
  expenses               expenses[]
  financial_calculations financial_calculations[]
  guide_pricing          guide_pricing[]
  agencies               agencies?                @relation(fields: [agency_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_guides__agency_id__agencies")
  users                  users                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_guides__user_id__users")
  income                 income[]
  personal_events        personal_events[]
  reservations           reservations[]
  reviews                reviews[]
  service_requests       service_requests[]
  staff_evaluations      staff_evaluations[]
  tour_assignments       tour_assignments[]
  user_favorites         user_favorites[]
  working_hours          working_hours[]

  @@index([guide_type], map: "idx_guides__guide_type")
  @@index([agency_id], map: "idx_guides__agency_id")
  @@index([languages], map: "idx_guides__languages", type: Gin)
  @@index([specialties], map: "idx_guides__specialties", type: Gin)
  @@index([status], map: "idx_guides__status")
}

model income {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guide_id           String            @db.Uuid
  type_id            String            @db.Uuid
  tour_id            String?           @db.Uuid
  reservation_id     String?           @db.Uuid
  amount             Decimal           @db.Decimal(10, 2)
  description        String?
  date               DateTime          @db.Date
  source             String?           @db.VarChar(100)
  notes              String?
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @db.Timestamptz(6)
  service_request_id String?           @db.Uuid
  service_requests   service_requests? @relation(fields: [service_request_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_income__service_request_id__service_requests")
  guides             guides            @relation(fields: [guide_id], references: [id], onDelete: Cascade)
  reservations       reservations?     @relation(fields: [reservation_id], references: [id])
  tours              tours?            @relation(fields: [tour_id], references: [id])
  income_types       income_types      @relation(fields: [type_id], references: [id])

  @@index([date], map: "idx_income__date")
  @@index([guide_id], map: "idx_income__guide_id")
  @@index([tour_id], map: "idx_income__tour_id")
  @@index([type_id], map: "idx_income__type_id")
  @@index([service_request_id], map: "idx_income__service_request_id")
}

model income_types {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  value       String   @unique @db.VarChar(50)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(20)
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  income      income[]

  @@index([value], map: "idx_income_types__value")
}

model locations {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id          String?              @db.Uuid
  name               String               @db.VarChar(150)
  type               String               @db.VarChar(30)
  code               String?              @db.VarChar(20)
  latitude           Decimal?             @db.Decimal(10, 7)
  longitude          Decimal?             @db.Decimal(10, 7)
  is_active          Boolean              @default(true)
  path               String?
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  emergency_contacts emergency_contacts[]
  locations          locations?           @relation("locationsTolocations", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_locations__parent_id__locations")
  other_locations    locations[]          @relation("locationsTolocations")
  providers          providers[]

  @@index([code], map: "idx_locations__code")
  @@index([name], map: "idx_locations__name")
  @@index([parent_id], map: "idx_locations__parent_id")
  @@index([path], map: "idx_locations__path")
  @@index([type], map: "idx_locations__type")
}

model messages {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id        String     @db.Uuid
  sender_id      String     @db.Uuid
  content        String?
  message_type   String     @default("text") @db.VarChar(20)
  status         String     @default("sent") @db.VarChar(20)
  reply_to_id    String?    @db.Uuid
  edited_at      DateTime?  @db.Timestamptz(6)
  deleted_at     DateTime?  @db.Timestamptz(6)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  chats          chats      @relation(fields: [chat_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_messages__chat_id__chats")
  messages       messages?  @relation("messagesTomessages", fields: [reply_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_messages__reply_to_id__messages")
  other_messages messages[] @relation("messagesTomessages")
  users          users      @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_messages__sender_id__users")

  @@index([chat_id], map: "idx_messages__chat_id")
  @@index([created_at], map: "idx_messages__created_at")
  @@index([message_type], map: "idx_messages__message_type")
  @@index([reply_to_id], map: "idx_messages__reply_to_id")
  @@index([sender_id], map: "idx_messages__sender_id")
}

model notification_config {
