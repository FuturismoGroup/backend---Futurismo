  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           String    @db.VarChar(30)
  label          String?   @db.VarChar(100)
  bank           String?   @db.VarChar(100)
  account_number String?   @db.VarChar(30)
  cci            String?   @db.VarChar(25)
  card_number    String?   @db.VarChar(20)
  phone_number   String?   @db.VarChar(20)
  holder_name    String?   @db.VarChar(200)
  currency       String?   @default("PEN") @db.VarChar(3)
  account_type   String?   @db.VarChar(20)
  card_type      String?   @db.VarChar(20)
  expiry_date    String?   @db.VarChar(10)
  description    String?
  is_main        Boolean?  @default(false)
  is_active      Boolean?  @default(true)
  sort_order     Int?      @default(0) @db.SmallInt
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_spm__is_active")
  @@index([type], map: "idx_spm__type")
}

model availability {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guide_id     String       @db.Uuid
  date         DateTime     @db.Date
  is_available Boolean      @default(true)
  notes        String?
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)
  guides       guides       @relation(fields: [guide_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_availability__guide_id__guides")
  time_slots   time_slots[]

  @@unique([guide_id, date], map: "availability_guide_date_unique")
  @@index([date], map: "idx_availability__date")
  @@index([guide_id, date], map: "idx_availability__guide_date")
  @@index([guide_id], map: "idx_availability__guide_id")
}

model guide_pricing {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guide_id         String             @db.Uuid
  service_name     String             @db.VarChar(200)
  description      String?
  price_per_person Decimal            @db.Decimal(10, 2)
  currency         String?            @default("PEN") @db.VarChar(3)
  min_group_size   Int?               @default(1)
  max_group_size   Int?               @default(50)
  duration_hours   Decimal?           @db.Decimal(4, 1)
  includes         String?
  active           Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  guides           guides             @relation(fields: [guide_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service_requests service_requests[]

  @@index([active], map: "idx_guide_pricing__active")
  @@index([guide_id], map: "idx_guide_pricing__guide_id")
}

model time_slots {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  availability_id String        @db.Uuid
  start_time      DateTime      @db.Time(6)
  end_time        DateTime      @db.Time(6)
  status          String        @default("available") @db.VarChar(20)
  reservation_id  String?       @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  availability    availability  @relation(fields: [availability_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_time_slots__availability_id__availability")
  reservations    reservations? @relation(fields: [reservation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_time_slots__reservation_id__reservations")

  @@index([availability_id], map: "idx_time_slots__availability_id")
  @@index([reservation_id], map: "idx_time_slots__reservation_id")
  @@index([status], map: "idx_time_slots__status")
}

model tour_incidents {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  active_tour_id String       @db.Uuid
  tour_stop_id   String?      @db.Uuid
  type           String       @db.VarChar(50)
  severity       String       @default("medium") @db.VarChar(20)
  description    String
  reported_by    String?      @db.Uuid
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  created_at     DateTime     @default(now()) @db.Timestamptz(6)
  active_tours   active_tours @relation(fields: [active_tour_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tour_incidents__active_tour_id__active_tours")
  tour_stops     tour_stops?  @relation(fields: [tour_stop_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tour_incidents__tour_stop_id__tour_stops")
  users          users?       @relation(fields: [reported_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_tour_incidents__reported_by__users")

  @@index([active_tour_id], map: "idx_tour_incidents__active_tour_id")
  @@index([created_at], map: "idx_tour_incidents__created_at")
  @@index([severity], map: "idx_tour_incidents__severity")
  @@index([type], map: "idx_tour_incidents__type")
}

model monitoring_alerts {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  active_tour_id  String?       @db.Uuid
  type            String        @db.VarChar(50)
  severity        String        @default("medium") @db.VarChar(20)
  message         String
  acknowledged    Boolean       @default(false)
  acknowledged_by String?       @db.Uuid
  acknowledged_at DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  active_tours    active_tours? @relation(fields: [active_tour_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_monitoring_alerts__active_tour_id__active_tours")
  users           users?        @relation(fields: [acknowledged_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_monitoring_alerts__acknowledged_by__users")

  @@index([acknowledged], map: "idx_monitoring_alerts__acknowledged")
  @@index([active_tour_id], map: "idx_monitoring_alerts__active_tour_id")
  @@index([created_at], map: "idx_monitoring_alerts__created_at")
  @@index([severity], map: "idx_monitoring_alerts__severity")
}

model user_permissions {
  id                                       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                  String      @db.Uuid
  permission_id                            String      @db.Uuid
  granted_at                               DateTime    @default(now()) @db.Timestamptz(6)
  granted_by                               String?     @db.Uuid
  permissions                              permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_permissions__permission_id__permissions")
  users_user_permissions_user_idTousers    users       @relation("user_permissions_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_permissions__user_id__users")
  users_user_permissions_granted_byTousers users?      @relation("user_permissions_granted_byTousers", fields: [granted_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_permissions__granted_by__users")

  @@unique([user_id, permission_id], map: "user_permissions_unique")
  @@index([permission_id], map: "idx_user_permissions__permission_id")
  @@index([user_id], map: "idx_user_permissions__user_id")
}
